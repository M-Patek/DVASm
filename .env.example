# DVAS Configuration

# API Keys for Teacher Models (at least one required)
OPENAI_API_KEY=sk-your-openai-key-here
ANTHROPIC_API_KEY=sk-ant-your-claude-key-here
TOGETHER_API_KEY=your-together-api-key

# Data Paths
DATA_ROOT=./data
EPIC_KITCHENS_ROOT=/path/to/EPIC-KITCHENS

# Model Settings
DEFAULT_TEACHER_MODEL=gpt-4o
TEACHER_MAX_CONCURRENT=10
TEACHER_RATE_LIMIT_RPM=500

# Quality Thresholds
QUALITY_MIN_SCORE=0.7
QUALITY_AUTO_APPROVE_THRESHOLD=0.9
QUALITY_HUMAN_REVIEW_THRESHOLD=0.6

# App Settings
DEBUG=false
LOG_LEVEL=INFO
